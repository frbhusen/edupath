{
  "expo": {
    "name": "Edupath",
    "slug": "study-platform-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/edupath-logo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.edupath.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/edupath-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "INTERNET"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "947c3cfd-7adc-4e49-9f81-dddc287abde5"
      }
    }
  }
}
